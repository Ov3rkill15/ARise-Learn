# === LLM Configuration ===
# Provider: "mock" | "gemini" | "openai"
LLM_PROVIDER=mock

# Google Gemini API (get key at https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# OpenAI API (get key at https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# === Database ===
# PostgreSQL connection (default for docker-compose)
POSTGRES_USER=edutech
POSTGRES_PASSWORD=edutech
POSTGRES_DB=edutech

# === Vector Database ===
# Qdrant runs on port 6333 by default
QDRANT_PORT=6333
